.DS_Store
.env
.pytest_cache/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.claude/

# Local runtime state
memory/*.json
memory.pilot.bak.*/
demo_workspace/
live_fast_workspace/
live_manual_workspace/
live_smoke_workspace/
live_test_workspace/

# Timestamped one-off run outputs; outputs/general_task_example1 and
# outputs/ML_task_example1 are curated examples and ARE kept.
outputs/[0-9]*/

# Per-run benchmark artifacts (regeneratable; per-task summary CSVs and
# rubric-judge JSONL under benchmarks/drb2/results/ ARE kept).
benchmarks/drb2/runs/

# Temporary render/check artifacts
tmp/
tmp_formula_check/
tmp_formula_check2/

# Common build artifacts
build/
dist/
htmlcov/
.coverage
